{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PROJECT_DIR:-.}\"/.claude/hooks/enforce-cs-rules.sh",
            "timeout": 30,
            "statusMessage": "Checking C# rules (per-project language regimes, cmdlet rules)..."
          },
          {
            "type": "command",
            "command": "\"${CLAUDE_PROJECT_DIR:-.}\"/.claude/hooks/enforce-psd1-rules.sh",
            "timeout": 15,
            "statusMessage": "Checking module manifests (no wildcard exports)..."
          },
          {
            "type": "command",
            "command": "\"${CLAUDE_PROJECT_DIR:-.}\"/.claude/hooks/stop-file-length.sh",
            "timeout": 15,
            "statusMessage": "Checking file lengths (400-line limit)..."
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}\"/.claude/hooks/stop-no-deflection.sh",
            "timeout": 30,
            "statusMessage": "Checking for deflected bug ownership..."
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}\"/.claude/hooks/stop-verify.sh",
            "timeout": 30,
            "statusMessage": "Quality gate: parity traps, both TFMs, cross-record legs..."
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}\"/.claude/hooks/stop-jscpd-ratchet.sh",
            "timeout": 180,
            "statusMessage": "Checking duplication ratchet (jscpd)..."
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PROJECT_DIR:-.}\"/.claude/hooks/stop-codex-review.sh",
            "timeout": 900,
            "statusMessage": "Codex cross-model review of changed C#..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|compact|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-context.sh",
            "timeout": 10,
            "statusMessage": "Re-injecting migration project rules..."
          }
        ]
      }
    ]
  }
}
